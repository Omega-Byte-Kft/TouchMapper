<Window x:Class="TouchMapper.Configurator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TouchMapper Configurator" Height="720" Width="900"
        MinHeight="520" MinWidth="680"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Page content -->
            <RowDefinition Height="50"/>   <!-- Nav buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1a73e8">
            <Grid Margin="20,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="PageTitle" FontSize="18" FontWeight="SemiBold"
                               Foreground="White" Text="TouchMapper"/>
                    <TextBlock x:Name="PageSubtitle" FontSize="11" Foreground="#cce0ff"
                               Text="Touch-to-display mapping configurator"/>
                </StackPanel>
                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Right"
                           FontSize="10" Foreground="#99ffffff" Text="Omega Byte Kft."/>
            </Grid>
        </Border>

        <!-- Current page content -->
        <ContentControl x:Name="PageContent" Grid.Row="1" Margin="0"/>

        <!-- Navigation -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#ddd" Background="#f5f5f5">
            <Grid Margin="16,0">
                <Button x:Name="BackButton" HorizontalAlignment="Left"
                        VerticalAlignment="Center" Content="Back"
                        Click="BackButton_Click" IsEnabled="False"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="NextButton" Content="Next"
                            Click="NextButton_Click" IsEnabled="False"/>
                    <Button x:Name="FinishButton" Content="Finish"
                            Click="FinishButton_Click" Margin="8,0,0,0"
                            Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
