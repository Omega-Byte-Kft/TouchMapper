<UserControl x:Class="TouchMapper.Configurator.Pages.ScanPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="32">
        <TextBlock Text="Scanning hardware..." FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <ProgressBar x:Name="Progress" IsIndeterminate="True" Height="6" Margin="0,0,0,20"/>

        <TextBlock x:Name="StatusText" Text="Starting scan..." Foreground="#555" Margin="0,0,0,16"/>

        <Border x:Name="ResultPanel" Visibility="Collapsed"
                Background="#f0f7ff" CornerRadius="4" Padding="16" Margin="0,8,0,0">
            <StackPanel>
                <TextBlock x:Name="MonitorCount" FontSize="13" Margin="0,2"/>
                <TextBlock x:Name="TouchCount"   FontSize="13" Margin="0,2"/>
                <TextBlock x:Name="GroupCount"   FontSize="13" Margin="0,2"/>
            </StackPanel>
        </Border>

        <Border x:Name="ErrorPanel" Visibility="Collapsed"
                Background="#fff0f0" CornerRadius="4" Padding="16" Margin="0,8,0,0">
            <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap"/>
        </Border>
    </StackPanel>
</UserControl>
