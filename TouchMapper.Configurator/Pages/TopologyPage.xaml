<UserControl x:Class="TouchMapper.Configurator.Pages.TopologyPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="#444" Margin="0,0,0,16">
            The topology below was discovered from USB location paths.
            Devices with fewer USB hops are "anchor" monitors — others daisy-chain through them.
            If a monitor is missing, check that its USB cable is connected.
        </TextBlock>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="GroupsList"/>
        </ScrollViewer>
    </Grid>
</UserControl>
