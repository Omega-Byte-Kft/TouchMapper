<UserControl x:Class="TouchMapper.Configurator.Pages.NamingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="#444" Margin="0,0,0,16">
            Give each monitor a friendly name to identify it in the config.
            The anchor monitor (★) is the one that other monitors daisy-chain through.
        </TextBlock>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="MonitorList"/>
        </ScrollViewer>
    </Grid>
</UserControl>
